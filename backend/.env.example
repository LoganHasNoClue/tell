# TELL backend — copy to .env. Demo mode needs NONE of these (it's offline-safe).
# Set these only to enable the LIVE scoring path.

# MiniMax M3 behind the Truefoundry gateway (OpenAI-compatible endpoint)
TELL_LLM_BASE_URL=https://<your-truefoundry-gateway>/openai/v1
TELL_LLM_API_KEY=
TELL_LLM_MODEL=minimax-m3
TELL_LLM_TIMEOUT=1.6

# Deepgram realtime STT (live audio path; demo replays authored captions instead)
DEEPGRAM_API_KEY=

# Moss — semantic retrieval over the ground-truth fact base (https://portal.usemoss.dev)
# Without these, the fact-checker falls back to a local keyword retriever.
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
